#!/bin/bash

# ===============================
# FAST PS5 TRACKER (STABLE)
# ===============================

if [ "$EUID" -ne 0 ]; then
    echo "Run with: sudo ./ps5_fast.sh"
    exit 1
fi

read -p "Enter PS5 IP: " PS5_IP

IFACE=$(ip route | grep default | awk '{print $5}')
[ -z "$IFACE" ] && IFACE="any"

DATA_FILE="/tmp/ps5_data.txt"
> "$DATA_FILE"

echo "🎮 Starting fast tracker..."
sleep 1

# Background packet capture (FAST, no lag)
tcpdump -i $IFACE host $PS5_IP -nn -l 2>/dev/null | while read line; do

    NOW=$(date +%s)

    echo "$line" | grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}\.[0-9]+' | while read ep; do
        IP=$(echo $ep | sed 's/\.[0-9]*$//')
        PORT=$(echo $ep | grep -oE '[0-9]+$')

        if [ "$IP" != "$PS5_IP" ]; then
            echo "$IP:$PORT $NOW" >> "$DATA_FILE"
        fi
    done

done &

# Display loop (smooth refresh)
while true; do
    clear
    echo "🎮 PS5 FAST TRACKER"
    echo "Time: $(date)"
    echo "Tracking: $PS5_IP"
    echo "======================================"

    NOW=$(date +%s)

    # Get unique endpoints
    awk '{print $1}' $DATA_FILE | sort | uniq > /tmp/ps5_unique.txt

    COUNT=$(wc -l < /tmp/ps5_unique.txt)
    echo "🌐 Total Endpoints: $COUNT"
    echo ""

    while read ep; do
        LAST=$(grep "$ep" $DATA_FILE | tail -n1 | awk '{print $2}')
        AGE=$((NOW - LAST))

        if [ "$AGE" -lt 5 ]; then
            STATUS="🟢 ACTIVE"
        else
            STATUS="🔴 IDLE"
        fi

        echo "$ep - $STATUS (${AGE}s ago)"
    done < /tmp/ps5_unique.txt

    echo ""
    echo "======================================"
    echo "Updating every 2s..."

    sleep 2
done
