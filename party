#!/bin/bash

# ===============================
# PS5 PARTY ACTIVITY MONITOR
# ===============================

if [ "$EUID" -ne 0 ]; then
    echo "Run with sudo ./ps5_party_monitor.sh"
    exit 1
fi

echo "🎮 PS5 Party Activity Monitor"
sleep 1

read -p "Enter PS5 IP: " PS5_IP
read -p "Enter hotspot interface (connected to PS5): " HOTSPOT_IF

# Temp files
DATA_FILE="/tmp/ps5_party_data.txt"
> "$DATA_FILE"
LAST_SEEN="/tmp/ps5_party_last.txt"
> "$LAST_SEEN"

# Background capture
tcpdump -i $HOTSPOT_IF host $PS5_IP -nn -l 2>/dev/null | while read line; do
    NOW=$(date +%s)

    ENDPOINTS=$(echo "$line" | grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}\.[0-9]+')
    for ep in $ENDPOINTS; do
        IP=$(echo $ep | sed 's/\.[0-9]*$//')
        PORT=$(echo $ep | grep -oE '[0-9]+$')
        if [ "$IP" != "$PS5_IP" ]; then
            KEY="$IP:$PORT"
            grep -v "^$KEY " $LAST_SEEN > ${LAST_SEEN}.tmp
            echo "$KEY $NOW" >> ${LAST_SEEN}.tmp
            mv ${LAST_SEEN}.tmp $LAST_SEEN
            if ! grep -q "^$KEY$" "$DATA_FILE"; then
                echo "$KEY" >> "$DATA_FILE"
            fi
        fi
    done
done &

# Display loop
while true; do
    clear
    echo "🎮 PS5 PARTY MONITOR"
    echo "Time: $(date)"
    echo "PS5 IP: $PS5_IP"
    echo "Interface: $HOTSPOT_IF"
    echo "======================================"

    NOW=$(date +%s)
    awk '{print $1}' $DATA_FILE | sort | uniq > /tmp/ps5_unique.txt
    COUNT=$(wc -l < /tmp/ps5_unique.txt)
    echo "🌐 Total Endpoints: $COUNT"
    echo ""

    while read ep; do
        LAST=$(grep "^$ep " $LAST_SEEN | tail -n1 | awk '{print $2}')
        AGE=$((NOW - LAST))
        if [ "$AGE" -lt 3 ]; then STATUS="🟢 ACTIVE"; else STATUS="🔴 IDLE"; fi

        # Voice spike detection (UDP traffic)
        if echo "$ep" | grep -qE "3478|3479|3480"; then
            ACT="🎤 Possible Voice Traffic"
        else
            ACT=""
        fi

        echo "$ep - $STATUS $ACT"
    done < /tmp/ps5_unique.txt

    echo ""
    echo "======================================"
    echo "Updating every 2s..."
    sleep 2
done
