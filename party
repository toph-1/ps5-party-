#!/bin/bash

# ===============================
# ADVANCED PS5 ENDPOINT TRACKER
# ===============================

if [ "$EUID" -ne 0 ]; then
    echo "Run with: sudo ./ps5_advanced.sh"
    exit 1
fi

# Install tools if missing
apt update >/dev/null
apt install -y tcpdump curl >/dev/null

read -p "Enter PS5 IP: " PS5_IP

# Detect interface
IFACE=$(ip route | grep default | awk '{print $5}')
[ -z "$IFACE" ] && IFACE="any"

TMP_FILE="/tmp/ps5_ips.txt"
> "$TMP_FILE"

LAST_SEEN="/tmp/ps5_last_seen.txt"
> "$LAST_SEEN"

clear
echo "🎮 ADVANCED PS5 TRACKER"
echo "Tracking: $PS5_IP"
echo "Interface: $IFACE"
echo "======================================"
sleep 2

tcpdump -i $IFACE host $PS5_IP -nn -l 2>/dev/null | while read line; do

    NOW=$(date +%s)

    IPS=$(echo "$line" | grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}')

    for ip in $IPS; do
        if [ "$ip" != "$PS5_IP" ]; then

            # Save last seen time
            grep -v "^$ip " $LAST_SEEN > ${LAST_SEEN}.tmp
            echo "$ip $NOW" >> ${LAST_SEEN}.tmp
            mv ${LAST_SEEN}.tmp $LAST_SEEN

            # If new IP
            if ! grep -q "^$ip$" "$TMP_FILE"; then
                echo "$ip" >> "$TMP_FILE"

                # Optional lookup
                INFO=$(curl -s "http://ip-api.com/line/$ip?fields=country,isp" | paste -sd " - ")

                echo ""
                echo "➕ NEW ENDPOINT: $ip"
                echo "   Info: $INFO"
                sleep 1
            fi
        fi
    done

    clear
    echo "🎮 ADVANCED PS5 TRACKER"
    echo "Time: $(date)"
    echo "PS5: $PS5_IP"
    echo "Interface: $IFACE"
    echo "======================================"

    COUNT=$(wc -l < "$TMP_FILE")
    echo "🌐 Total Unique Endpoints: $COUNT"
    echo ""

    echo "📡 Active Endpoints:"
    while read ip; do
        LAST=$(grep "^$ip " $LAST_SEEN | awk '{print $2}')
        AGE=$((NOW - LAST))

        if [ "$AGE" -lt 10 ]; then
            STATUS="🟢 ACTIVE"
        else
            STATUS="🔴 IDLE"
        fi

        echo "$ip - $STATUS (${AGE}s ago)"
    done < "$TMP_FILE"

    echo ""
    echo "======================================"
    echo "Watching live traffic..."
done
